#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ZED_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zed"

link_json_files() {
  shopt -s nullglob
  local files=("$SCRIPT_DIR"/*.json)
  shopt -u nullglob

  if [[ ${#files[@]} -eq 0 ]]; then
    printf 'No .json files found in %s\n' "$SCRIPT_DIR" >&2
    return 1
  fi

  mkdir -p "$ZED_CONFIG_DIR"

  local source destination
  for source in "${files[@]}"; do
    destination="$ZED_CONFIG_DIR/${source##*/}"
    ln -sfn "$source" "$destination"
    printf 'Linked %s -> %s\n' "$destination" "$source"
  done
}

link_json_files
